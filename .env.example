# AdaWindOS — Configuration
# Copy this to .env and fill in your keys

# DeepSeek API key (required — LLM brain)
# Get one at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here

# Microsoft Azure Speech (optional — cloud TTS voice)
# Create at: https://portal.azure.com → Cognitive Services → Speech
# AZURE_SPEECH_KEY=your-key-here
# AZURE_SPEECH_REGION=eastus

# PostgreSQL (matches docker-compose.yml, usually no change needed)
POSTGRES_PASSWORD=ada_local
