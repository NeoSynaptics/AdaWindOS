{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "brainstorm", "note", "dispatch", "question", "decision",
        "command", "followup", "greeting", "farewell",
        "acknowledgement", "clarification", "noop"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "target_agent": {
      "type": ["string", "null"],
      "enum": ["ARCH", "FORGE", null]
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "note_action": {
      "type": "string",
      "enum": ["create", "update", "none"]
    },
    "topic": {
      "type": "string"
    },
    "references_existing": {
      "type": "boolean"
    }
  },
  "required": [
    "intent", "confidence", "target_agent", "urgency",
    "note_action", "topic", "references_existing"
  ]
}
